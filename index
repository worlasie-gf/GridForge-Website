<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>GridForge Energy | Trust for the Flexible Grid</title>
  <meta name="description" content="GridForge Energy is the infrastructure layer that verifies and coordinates flexible electricity demand." />
  <style>
    :root {
      --bg: #f4fbff;
      --bg-soft: #eaf7fc;
      --text: #082653;
      --muted: #61718a;
      --blue: #2d7bec;
      --cyan: #20bfd0;
      --border: rgba(8, 38, 83, 0.12);
      --shadow: 0 30px 80px rgba(34, 111, 214, 0.18);
      --radius: 28px;
      color-scheme: light;
    }

    * { box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 50% 17%, rgba(32, 191, 208, 0.20), transparent 33%),
        radial-gradient(circle at 50% 72%, rgba(45, 123, 236, 0.11), transparent 31%),
        linear-gradient(180deg, #ffffff 0%, var(--bg) 48%, #edf8fc 100%);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(8, 38, 83, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(8, 38, 83, 0.035) 1px, transparent 1px);
      background-size: 120px 120px;
      mask-image: linear-gradient(to bottom, black 0%, black 86%, transparent 100%);
    }

    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: clamp(28px, 6vw, 76px) 24px;
    }

    .hero {
      width: min(100%, 1440px);
      text-align: center;
      padding: clamp(28px, 5vw, 64px) 0;
    }

    .logo-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: clamp(32px, 5vw, 54px);
    }

    .logo {
      width: clamp(230px, 23vw, 410px);
      height: auto;
      display: block;
      filter: drop-shadow(0 14px 26px rgba(35, 143, 187, 0.18));
    }

    h1 {
      margin: 0;
      font-size: clamp(4rem, 9vw, 10.5rem);
      line-height: 0.9;
      letter-spacing: -0.085em;
      font-weight: 850;
      color: var(--text);
      text-wrap: balance;
    }

    .gradient {
      display: inline-block;
      background: linear-gradient(96deg, var(--blue) 12%, var(--cyan) 92%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .subtitle {
      max-width: 1120px;
      margin: clamp(54px, 6vw, 86px) auto 0;
      color: var(--muted);
      font-size: clamp(1.28rem, 2vw, 2.25rem);
      line-height: 1.34;
      letter-spacing: -0.035em;
    }

    .cta-row {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 28px;
      flex-wrap: wrap;
      margin-top: clamp(70px, 7vw, 112px);
    }

    .button {
      appearance: none;
      border: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: min(100%, 380px);
      min-height: 88px;
      padding: 0 54px;
      border-radius: 999px;
      font-size: clamp(1.05rem, 1.22vw, 1.35rem);
      font-weight: 800;
      letter-spacing: -0.015em;
      text-decoration: none;
      cursor: pointer;
      transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
    }

    .button.primary {
      color: #ffffff;
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      box-shadow: var(--shadow);
    }

    .button.secondary {
      color: var(--text);
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid var(--border);
      box-shadow: 0 20px 50px rgba(8, 38, 83, 0.08);
    }

    .button:hover {
      transform: translateY(-3px);
      filter: brightness(1.02);
    }

    .modal {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 22px;
      background: rgba(7, 18, 35, 0.42);
      backdrop-filter: blur(12px);
    }

    .modal.open { display: flex; }

    .modal-card {
      width: min(100%, 540px);
      border-radius: 28px;
      background: #ffffff;
      box-shadow: 0 34px 90px rgba(8, 38, 83, 0.28);
      border: 1px solid var(--border);
      padding: 30px;
      text-align: left;
    }

    .modal-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 18px;
      margin-bottom: 22px;
    }

    .modal h2 {
      margin: 0 0 8px;
      font-size: 1.8rem;
      letter-spacing: -0.045em;
    }

    .modal p {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
    }

    .close {
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: #f6fbfe;
      color: var(--text);
      font-size: 24px;
      cursor: pointer;
    }

    form {
      display: grid;
      gap: 14px;
    }

    label {
      display: grid;
      gap: 7px;
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--text);
    }

    input, textarea {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 15px 16px;
      font: inherit;
      color: var(--text);
      background: #f7fbfe;
      outline: none;
    }

    input:focus, textarea:focus {
      border-color: rgba(45, 123, 236, 0.55);
      box-shadow: 0 0 0 4px rgba(45, 123, 236, 0.12);
    }

    textarea { resize: vertical; min-height: 110px; }

    .submit {
      margin-top: 8px;
      min-width: 100%;
      min-height: 62px;
      font-size: 1rem;
    }

    .note {
      min-height: 22px;
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    @media (max-width: 720px) {
      .cta-row { gap: 16px; }
      .button { width: 100%; min-width: 0; min-height: 70px; }
      h1 { font-size: clamp(3.25rem, 17vw, 5.4rem); }
      .subtitle { margin-top: 42px; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero" aria-label="GridForge Energy landing page">
      <div class="logo-wrap">
        <img class="logo" src="data:image/png;base64," alt="GridForge Energy logo" />
      </div>

      <h1>Trust for the<br><span class="gradient">Flexible Grid</span></h1>

      <p class="subtitle">The infrastructure layer that verifies and coordinates flexible electricity demand.</p>

      <div class="cta-row">
        <button class="button primary" type="button" id="openForm">Get early access</button>
      </div>
    </section>
  </main>

  <div class="modal" id="leadModal" aria-hidden="true">
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-top">
        <div>
          <h2 id="modalTitle">Get early access</h2>
          <p>Share your details and GridForge will follow up.</p>
        </div>
        <button class="close" type="button" id="closeForm" aria-label="Close form">×</button>
      </div>

      <form id="leadForm">
        <label>Name
          <input name="name" autocomplete="name" required />
        </label>
        <label>Email
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>Company
          <input name="company" autocomplete="organization" />
        </label>
        <label>Message
          <textarea name="message" placeholder="What are you interested in?"></textarea>
        </label>
        <button class="button primary submit" type="submit">Submit</button>
        <div class="note" id="formNote"></div>
      </form>
    </div>
  </div>

  <script>
    // Paste your Google Apps Script Web App URL between the quotation marks below.
    const GOOGLE_SCRIPT_URL = "";

    const modal = document.getElementById("leadModal");
    const openForm = document.getElementById("openForm");
    const closeForm = document.getElementById("closeForm");
    const form = document.getElementById("leadForm");
    const note = document.getElementById("formNote");

    function showModal() {
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
    }

    function hideModal() {
      modal.classList.remove("open");
      modal.setAttribute("aria-hidden", "true");
    }

    openForm.addEventListener("click", showModal);
    closeForm.addEventListener("click", hideModal);
    modal.addEventListener("click", (event) => {
      if (event.target === modal) hideModal();
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      data.submittedAt = new Date().toISOString();

      if (!GOOGLE_SCRIPT_URL) {
        note.textContent = "Form captured locally. Add your Google Apps Script URL in the HTML to send this to Google Sheets.";
        console.log("GridForge lead form submission:", data);
        return;
      }

      note.textContent = "Submitting...";
      try {
        await fetch(GOOGLE_SCRIPT_URL, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: JSON.stringify(data)
        });
        form.reset();
        note.textContent = "Thanks — your request was submitted.";
      } catch (error) {
        note.textContent = "Something went wrong. Please email GridForge instead.";
      }
    });
  </script>
</body>
</html>